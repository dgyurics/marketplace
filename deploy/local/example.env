# General Configuration
APP_ID=marketplace
BASE_URL=http://localhost
ENVIRONMENT=development
MACHINE_ID=0

# Server Configuration
SERVER_ADDR=:8000
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=15s
SERVER_MAX_HEADER_BYTES=0

# Postgres Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketplace
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNECTIONS=80
POSTGRES_MAX_IDLE_CONNECTIONS=5
POSTGRES_CONNECTION_MAX_LIFETIME=30m
POSTGRES_CONNECTION_MAX_IDLE_TIME=15m

# Logging Configuration
LOG_LEVEL=debug

# Stripe Configuration
STRIPE_BASE_URL=https://api.stripe.com/v1
STRIPE_SECRET_KEY=secret-key
STRIPE_WEBHOOK_SIGNING_SECRET=signing-secret
STRIPE_VERSION=2025-04-30.basil

# Country Configuration (ISO 3166-1 alpha-2)
COUNTRY=US

# Tax Configuration
TAX_BEHAVIOR=exclusive
TAX_FALLBACK_CODE=txcd_99999999

# Disable rate limiting in local development
RATE_LIMIT_ENABLED=false

# Email Configuration
MAIL_ENABLED=true
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_USE_TLS=false
MAIL_FROM_EMAIL=noreply@selfco.io
MAIL_FROM_NAME=Marketplace

# Auth Configuration
JWT_EXPIRY=744h # 31 days
REFRESH_EXPIRY=744h # 31 days
HMAC_SECRET=secret
PRIVATE_KEY_PATH=./deploy/local/private.pem
PUBLIC_KEY_PATH=./deploy/local/public.pem

# Image Configuration
IMG_DIR_OVERRIDE=./deploy/local/images

# Image Proxy Configuration
IMGPROXY_LOCAL_FILESYSTEM_ROOT=/images
IMGPROXY_AUTO_WEBP=true
IMGPROXY_ENABLE_DEBUG_HEADERS=true
IMGPROXY_ALLOW_UNSAFE_URLS=false
IMGPROXY_MAX_SRC_RESOLUTION=200
IMGPROXY_MAX_SRC_FILE_SIZE=31457280
IMGPROXY_CONCURRENCY=3
IMGPROXY_SIGNATURE_SIZE=32
IMGPROXY_BIND=:80
IMGPROXY_KEY=75f5ea4b9c93a76c8f621b3f1ec7214db81c468c85c25a787af0367291fc6316
IMGPROXY_SALT=b911dd684612be776760ee198acc5673c79ea545558ff3bbe9c6cea640f15f9e

# Remove Background Configuration
REMBG_BASE_URL=http://localhost:5532

# Frontend Configuration (VITE_ prefix required for client-side access)
VITE_API_URL=http://localhost/api
VITE_STRIPE_PUBLISHABLE_KEY=publishable-key
VITE_REQUEST_TIMEOUT=30000
