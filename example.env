# General Configuration
APP_ID=marketplace # Used for logging purposes
ENVIRONMENT=development # development, production
BASE_URL=https://marketplace.com # full url of the application, including https://
PORT=8000

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/marketplace?sslmode=disable
DATABASE_MAX_CONNECTIONS=80
DATABASE_MAX_IDLE_CONNECTIONS=5
DATABASE_CONNECTION_MAX_LIFETIME=30m
DATABASE_CONNECTION_MAX_IDLE_TIME=15m

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE_PATH=log.log

# Stripe Configuration
STRIPE_BASE_URL=https://api.stripe.com/v1
STRIPE_SECRET_KEY=sk_test_xxxxxxx
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxx

# Email Configuration
EMAIL_ENABLED=false
MAILJET_API_KEY=2bb4xxxx
MAILJET_API_SECRET=3f61xxxx
MAILJET_FROM_EMAIL=youremail@xxxxxx.io
MAILJET_FROM_NAME=Marketplace

# JWT Configuration
DURATION_ACCESS_TOKEN=15m # 15 minutes
DURATION_REFRESH_TOKEN=24h # 1 day
